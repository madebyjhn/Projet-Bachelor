# =============================================================
# .env.example – copier vers .env et remplir les vraies valeurs
# Ce fichier est versionné. .env ne l'est PAS.
# =============================================================

# ---- Base de données MySQL ----------------------------------
# DB_HOST doit correspondre au nom du service Compose (pas localhost)
DB_HOST=mysql
DB_USER=startuplab
DB_PASSWORD=change_me_strong_password
DB_DATABASE=startuplab

# Mot de passe root MySQL (utilisé par le service mysql dans Compose)
MYSQL_ROOT_PASSWORD=change_me_root_password

# ---- Authentification ---------------------------------------
# Générer avec : openssl rand -base64 32
JWT_SECRET=change_me_jwt_secret_minimum_32_chars

# ---- Email (Nodemailer) -------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ---- Application --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
